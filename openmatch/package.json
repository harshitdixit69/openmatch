{
  "name": "openmatch",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@stripe/stripe-react-native": "0.64.0",
    "@supabase/supabase-js": "^2.106.1",
    "expo": "~56.0.15",
    "expo-apple-authentication": "~56.0.4",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.15",
    "expo-dev-client": "~56.0.22",
    "expo-image-picker": "~56.0.20",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "build": "expo export --platform web --output-dir dist",
    "vercel-build": "expo export --platform web --output-dir dist",
    "backfill:embeddings": "node ./scripts/backfillProfileEmbeddings.mjs",
    "check:phase3": "node ./scripts/phase3IntegrationCheck.mjs",
    "check:phase3:cleanup": "node ./scripts/phase3IntegrationCheck.mjs --cleanup",
    "check:phase4": "node ./scripts/phase4EscrowCheck.mjs",
    "check:phase4:cleanup": "node ./scripts/phase4EscrowCheck.mjs --cleanup",
    "check:phase8:broker": "node ./scripts/phase8BrokerCheck.mjs",
    "check:phase8:broker:cleanup": "node ./scripts/phase8BrokerCheck.mjs --cleanup"
  },
  "private": true
}
