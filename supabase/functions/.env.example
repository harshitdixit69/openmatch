# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (SERVER-SIDE ONLY)
# ---------------------------------------------------------------------------
# These are NOT prefixed with EXPO_PUBLIC_ and must NEVER be added to the
# frontend openmatch/.env file — they would be bundled into the app and exposed
# to every user. Set them on Supabase with:
#
#   supabase secrets set --project-ref <PROJECT_REF> \
#     CISCO_CLIENT_ID=... CISCO_CLIENT_SECRET=... CISCO_APP_KEY=...
#
# For local `supabase functions serve`, copy this file to
# `supabase/functions/.env` and fill in real values.
# ---------------------------------------------------------------------------

# --- Cisco Enterprise AI (chat / matchmaking LLM) ---------------------------
# The edge functions mint a short-lived access token from CISCO_TOKEN_URL using
# the client_credentials grant, then call the OpenAI-compatible chat endpoint.
CISCO_CLIENT_ID=your_cisco_client_id
CISCO_CLIENT_SECRET=your_cisco_client_secret
CISCO_APP_KEY=your_cisco_app_key

# Optional overrides (sensible defaults are baked in):
# CISCO_TOKEN_URL=https://id.cisco.com/oauth2/default/v1/token
# CISCO_AI_BASE_URL=https://chat-ai.cisco.com
# CISCO_AI_DEPLOYMENT=gemini-3.1-flash-lite

# --- Azure OpenAI (optional fallback) ---------------------------------------
# If the CISCO_* secrets above are absent, the functions fall back to Azure.
# Embeddings (generate-profile-embedding) still use Azure regardless.
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
